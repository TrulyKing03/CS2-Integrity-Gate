{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "SqlitePath": "data/controlplane.db"
  },
  "AcPolicy": {
    "JoinTokenSecret": "replace-this-in-production-with-64-byte-random-secret",
    "JoinTokenTtlSec": 90,
    "HeartbeatIntervalSec": 10,
    "GraceWindowSec": 60,
    "DefaultQueueTier": "high_trust",
    "PolicyVersion": "pol_2026_03_02_01",
    "RequiredTierA": {
      "SecureBoot": true,
      "Tpm20": true
    },
    "RequiredTierB": {
      "Iommu": true,
      "Vbs": false
    }
  },
  "AllowedHosts": "*"
}
