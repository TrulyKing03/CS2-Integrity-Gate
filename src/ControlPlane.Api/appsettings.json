{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "SqlitePath": "data/controlplane.db"
  },
  "AcPolicy": {
    "JoinTokenSecret": "replace-this-in-production-with-64-byte-random-secret",
    "JoinTokenTtlSec": 90,
    "HeartbeatIntervalSec": 10,
    "GraceWindowSec": 60,
    "DefaultQueueTier": "high_trust",
    "PolicyVersion": "pol_2026_03_02_01",
    "RequireAntiTamperOnMatchStart": true,
    "RequiredPolicyHashes": [
      "sha256:local_policy_hash"
    ],
    "RequiredTierA": {
      "SecureBoot": true,
      "Tpm20": true
    },
    "RequiredTierB": {
      "Iommu": true,
      "Vbs": false
    },
    "Detection": {
      "MinAimSamples": 30,
      "MinTriggerSamples": 20,
      "MinInfoSamples": 25,
      "MinMovementSamples": 80,
      "MovementScoreScale": 220.0,
      "AimHitRatioBaseline": 0.45,
      "AimScoreScale": 180.0,
      "TriggerScoreScale": 170.0,
      "InfoScoreScale": 160.0,
      "RulesViolationScoreScale": 20.0,
      "RulesTickActionMinViolations": 3,
      "RulesShotActionMinViolations": 4,
      "BehaviorActionMinSamples": 40,
      "MovementActionScoreThreshold": 97.0,
      "AimActionScoreThreshold": 98.0,
      "TriggerActionScoreThreshold": 98.0,
      "InfoActionScoreThreshold": 98.0,
      "BehaviorActionType": "queue_restrict",
      "BehaviorActionDurationSec": 3600,
      "ActionCooldownSec": 30
    }
  },
  "ApiAuth": {
    "ServerApiKey": "dev-server-api-key",
    "InternalApiKey": "dev-internal-api-key",
    "RequireQueueAccessToken": false,
    "AccessTokenTtlMinutes": 180
  },
  "ApiRateLimit": {
    "PublicAuth": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "PublicClient": {
      "PermitLimit": 240,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "ServerApi": {
      "PermitLimit": 3000,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "InternalApi": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Evidence": {
    "StorageDirectory": "evidence",
    "RecentTelemetryLimit": 300,
    "RecentHeartbeatsLimit": 30
  },
  "DataRetention": {
    "Enabled": true,
    "RunOnStartup": true,
    "SweepIntervalMinutes": 15,
    "JoinTokenRetentionMinutes": 180,
    "HeartbeatRetentionHours": 72,
    "TelemetryRetentionHours": 72
  },
  "AllowedHosts": "*"
}
