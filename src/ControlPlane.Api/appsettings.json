{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Storage": {
    "SqlitePath": "data/controlplane.db"
  },
  "AcPolicy": {
    "JoinTokenSecret": "replace-this-in-production-with-64-byte-random-secret",
    "JoinTokenTtlSec": 90,
    "HeartbeatIntervalSec": 10,
    "GraceWindowSec": 60,
    "DefaultQueueTier": "high_trust",
    "PolicyVersion": "pol_2026_03_02_01",
    "RequiredTierA": {
      "SecureBoot": true,
      "Tpm20": true
    },
    "RequiredTierB": {
      "Iommu": true,
      "Vbs": false
    }
  },
  "ApiAuth": {
    "ServerApiKey": "dev-server-api-key",
    "InternalApiKey": "dev-internal-api-key"
  },
  "ApiRateLimit": {
    "PublicAuth": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "PublicClient": {
      "PermitLimit": 240,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "ServerApi": {
      "PermitLimit": 3000,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "InternalApi": {
      "PermitLimit": 600,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "Evidence": {
    "StorageDirectory": "evidence",
    "RecentTelemetryLimit": 300,
    "RecentHeartbeatsLimit": 30
  },
  "AllowedHosts": "*"
}
