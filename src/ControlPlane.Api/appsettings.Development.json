{
  "AcPolicy": {
    "RequireAntiTamperOnMatchStart": true,
    "RequiredPolicyHashes": [
      "sha256:local_policy_hash"
    ]
  },
  "Evidence": {
    "AutoCreateReviewCases": true,
    "AutoReviewPriority": "high",
    "AutoReviewRequestedBy": "auto_detection",
    "AutoReviewTriggerAllowList": [
      "rules_impossible_state",
      "rules_fire_cadence"
    ]
  },
  "DataRetention": {
    "Enabled": true,
    "RunOnStartup": true,
    "SweepIntervalMinutes": 15,
    "JoinTokenRetentionMinutes": 180,
    "HeartbeatRetentionHours": 72,
    "SecurityEventRetentionHours": 168,
    "TelemetryRetentionHours": 72
  },
  "SecurityAlerts": {
    "Enabled": true,
    "SweepIntervalSeconds": 30,
    "WindowMinutes": 10,
    "MediumThreshold": 20,
    "HighThreshold": 1,
    "CooldownMinutes": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
